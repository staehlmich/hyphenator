{
  "manifest_version": 3,
  "name": "German Text Hyphenator",
  "version": "2.0.0",
  "description": "Add soft hyphens to selected German text while keeping URLs intact.",
  "homepage_url": "https://github.com/staehlmich/hyphenator",
  "permissions": [
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "hyphenator@staehlmich",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vendor/hypher.js", "vendor/de_extension.js", "content.js"]
    }
  ]
}
